// Vision Audit Flow Pro — Prisma Schema (MariaDB 11.x)
// Datasource: MariaDB via mysql connector

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH / USERS
// ============================================

enum Role {
  ADMIN
  MANAGER
  AUDITOR
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          Role      @default(AUDITOR)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  auditsCreated   Audit[]            @relation("AuditCreatedBy")
  auditsAssigned  Audit[]            @relation("AuditAssignedTo")
  auditReviews    AuditItemReview[]
  notifications   Notification[]
  activityLogs    ActivityLog[]

  @@index([role])
  @@index([isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// INVENTORY
// ============================================

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  color       String?  @default("#3a64ff")
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Location {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  type        LocationType @default(WAREHOUSE)
  address     String?      @db.Text
  city        String?
  country     String?
  manager     String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  stockItems StockItem[]
  audits     Audit[]

  @@index([type])
  @@index([isActive])
}

enum LocationType {
  WAREHOUSE
  STORE
  STOCKROOM
  TRANSIT
  OTHER
}

model Product {
  id           String    @id @default(cuid())
  sku          String    @unique
  barcode      String?   @unique
  name         String
  description  String?   @db.Text
  imageUrl     String?
  categoryId   String?
  unit         String    @default("pcs")
  costPrice    Decimal?  @db.Decimal(12, 2)
  sellPrice    Decimal?  @db.Decimal(12, 2)
  reorderPoint Int       @default(0)
  reorderQty   Int       @default(0)
  isActive     Boolean   @default(true)
  tags         String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stockItems StockItem[]
  auditItems AuditItem[]

  @@index([sku])
  @@index([barcode])
  @@index([categoryId])
  @@index([isActive])
  @@fulltext([name, description, tags])
}

model StockItem {
  id           String   @id @default(cuid())
  productId    String
  locationId   String
  quantity     Int      @default(0)
  reservedQty  Int      @default(0)
  lastCountedAt DateTime?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
  @@index([locationId])
  @@index([productId])
}

// ============================================
// AUDIT (AI-Powered)
// ============================================

enum AuditStatus {
  DRAFT
  IN_PROGRESS
  PROCESSING
  REVIEW
  COMPLETED
  CANCELLED
}

enum AuditMethod {
  AI_VISION
  BARCODE_SCAN
  MANUAL
  HYBRID
}

model Audit {
  id            String       @id @default(cuid())
  code          String       @unique
  title         String
  description   String?      @db.Text
  status        AuditStatus  @default(DRAFT)
  method        AuditMethod  @default(AI_VISION)
  locationId    String
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdById   String
  assignedToId  String?
  totalItems    Int          @default(0)
  matchedItems  Int          @default(0)
  discrepancies Int          @default(0)
  aiConfidence  Float?
  aiSummary     String?      @db.Text
  notes         String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  location   Location    @relation(fields: [locationId], references: [id])
  createdBy  User        @relation("AuditCreatedBy", fields: [createdById], references: [id])
  assignedTo User?       @relation("AuditAssignedTo", fields: [assignedToId], references: [id])
  scans      AuditScan[]
  items      AuditItem[]

  @@index([status])
  @@index([locationId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([scheduledAt])
}

model AuditScan {
  id          String   @id @default(cuid())
  auditId     String
  imageUrl    String
  thumbnail   String?
  mimeType    String   @default("image/jpeg")
  fileSize    Int      @default(0)
  width       Int?
  height      Int?
  aiProcessed Boolean  @default(false)
  aiModel     String?
  aiLatencyMs Int?
  rawAiOutput String?  @db.LongText
  notes       String?  @db.Text
  capturedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  audit Audit       @relation(fields: [auditId], references: [id], onDelete: Cascade)
  items AuditItem[]

  @@index([auditId])
}

enum AuditItemStatus {
  DETECTED
  MATCHED
  MISSING
  EXTRA
  DAMAGED
  UNKNOWN
}

model AuditItem {
  id            String          @id @default(cuid())
  auditId       String
  scanId        String?
  productId     String?
  detectedLabel String
  detectedQty   Int             @default(1)
  expectedQty   Int             @default(0)
  status        AuditItemStatus @default(DETECTED)
  confidence    Float?
  boundingBox   Json?
  notes         String?         @db.Text
  resolved      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  audit   Audit             @relation(fields: [auditId], references: [id], onDelete: Cascade)
  scan    AuditScan?        @relation(fields: [scanId], references: [id], onDelete: SetNull)
  product Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  reviews AuditItemReview[]

  @@index([auditId])
  @@index([scanId])
  @@index([productId])
  @@index([status])
}

model AuditItemReview {
  id           String   @id @default(cuid())
  auditItemId  String
  reviewerId   String
  action       String   // approved, rejected, edited
  prevQty      Int?
  newQty       Int?
  comment      String?  @db.Text
  createdAt    DateTime @default(now())

  auditItem AuditItem @relation(fields: [auditItemId], references: [id], onDelete: Cascade)
  reviewer  User      @relation(fields: [reviewerId], references: [id])

  @@index([auditItemId])
  @@index([reviewerId])
}

// ============================================
// AI INSIGHTS / ANOMALIES
// ============================================

enum InsightSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model AiInsight {
  id          String          @id @default(cuid())
  title       String
  category    String
  severity    InsightSeverity @default(INFO)
  summary     String          @db.Text
  details     String?         @db.LongText
  modelUsed   String?
  entityType  String? // "product", "location", "audit"
  entityId    String?
  acknowledged Boolean        @default(false)
  createdAt   DateTime        @default(now())

  @@index([severity])
  @@index([entityType, entityId])
  @@index([acknowledged])
}

// ============================================
// SYSTEM
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  type      String   @default("info")
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Setting {
  key       String   @id
  value     String   @db.LongText
  updatedAt DateTime @updatedAt
}
