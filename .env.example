# =========================================
# Vision Audit Flow Pro — Environment
# =========================================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Vision Audit Flow Pro"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (MariaDB 11.x)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://vision_user:CHANGE_ME@localhost:3306/vision_audit_flow"

# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_A_LONG_RANDOM_STRING"
AUTH_TRUST_HOST=true

# Google Gemini API (used for Vision + AI insights)
# Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
# Model identifiers (override to swap in newer 2026 models when GA)
GEMINI_VISION_MODEL="gemini-2.0-flash-exp"
GEMINI_TEXT_MODEL="gemini-1.5-pro"

# Storage (local file system path for uploaded audit images)
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_MB=20

# Branding
BRAND_PRIMARY_COLOR="#3a64ff"
